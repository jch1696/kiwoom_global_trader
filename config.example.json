{
  "google": {
    "spreadsheet_id": "",
    "credential_file": "data/credentials.json",
    "order_sheet_mode": "all_tabs",
    "exclude_sheets": ["정산", "README", "설명", "템플릿", "TEMPLATE"],
    "settlement_sheet_name": "정산",
